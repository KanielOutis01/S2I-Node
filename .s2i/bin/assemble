#!/bin/bash
set -e

echo "Starting S2I assemble..."

APP_SRC_DIR="/tmp/src"
TARGET_DIR="/opt/app-root/src"

mkdir -p ${TARGET_DIR}

DIST_DIR=$(find ${APP_SRC_DIR}/dist -mindepth 1 -maxdepth 1 -type d | head -n 1)

if [ -z "$DIST_DIR" ]; then
  echo "ERROR: No Angular dist folder found!"
  exit 1
fi

echo "Copying Angular files from browser folder..."

cp -r ${DIST_DIR}/browser/* ${TARGET_DIR}/

echo "Files copied successfully"