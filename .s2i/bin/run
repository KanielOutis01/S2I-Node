cat <<EOF > /tmp/nginx.conf
events {}

http {
    include       /etc/nginx/mime.types;
    default_type  application/octet-stream;

    server {
        listen 8080;

        root /opt/app-root/src;
        index index.html;

        location / {
            try_files \$uri /index.html;
        }
    }
}
EOF

nginx -c /tmp/nginx.conf -g "daemon off;"